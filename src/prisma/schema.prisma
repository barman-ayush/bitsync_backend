// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String   @unique @db.VarChar(255)
  username           String   @db.VarChar(39)
  usernameNormalized String   @unique @db.VarChar(39) @map("username_normalized")
  displayName        String   @db.VarChar(100) @map("display_name")
  avatarUrl          String?  @map("avatar_url")
  passwordHash       String?  @map("password_hash")  // NULL if user signed up via OAuth only
  emailVerified      Boolean  @default(false) @map("email_verified")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  refreshTokens        RefreshToken[]
  ownedRepos           Repository[]   @relation("RepoOwner")
  repoMemberships      RepoMember[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsActed    Notification[] @relation("NotificationActor")

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid @map("user_id")
  tokenHash  String    @unique @db.VarChar(255) @map("token_hash")
  deviceInfo String?   @db.VarChar(255) @map("device_info")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revoked    Boolean   @default(false)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Repository {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String   @db.VarChar(255)
  nameNormalized String   @db.VarChar(255) @map("name_normalized")
  description    String?  @db.Text
  ownerId        String   @db.Uuid @map("owner_id")
  headCommit     String?  @db.Text @map("head_commit")
  isDeleted      Boolean  @default(false) @map("is_deleted")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  owner       User          @relation("RepoOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     RepoMember[]

  @@unique([ownerId, nameNormalized])
  @@index([ownerId])
  @@map("repositories")
}

enum RepoRole {
  owner
  admin
  member

  @@map("repo_role")
}

model RepoMember {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  repoId    String    @db.Uuid @map("repo_id")
  userId    String    @db.Uuid @map("user_id")
  role      RepoRole  @default(member)
  joinedAt  DateTime  @default(now()) @map("joined_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  repo Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([repoId, userId])
  @@index([repoId])
  @@index([userId])
  @@map("repo_members")
}

enum NotificationType {
  repo_invite
  invite_accepted
  invite_declined
  pr_created
  pr_merged
  pr_rejected
  pr_reviewed
  pr_reverted
  merge_conflicts
  member_removed
  role_changed

  @@map("notification_type")
}

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String           @db.Uuid @map("user_id")  // recipient (inbox owner)
  actorId   String?          @db.Uuid @map("actor_id") // who triggered it; null for system events
  type      NotificationType
  title     String           @db.VarChar(255)
  body      String?          @db.Text
  data      Json?            // structured payload: repoId, role, prId, etc. (snapshot, no FK)
  isRead    Boolean          @default(false) @map("is_read")
  expiresAt DateTime?        @map("expires_at") @db.Timestamptz // set for repo_invite; powers expiry cleanup
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("notifications")
}
